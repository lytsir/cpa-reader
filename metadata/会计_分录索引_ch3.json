{
  "会计-第3章": {
    "title": "第三章 固定资产 — 本章会计分录",
    "entries": [
      {
        "category": "一、初始计量",
        "items": [
          {
            "title": "外购不需安装的固定资产",
            "debit": [
              {"科目": "固定资产", "金额": "买价+相关税费+运输费+装卸费+安装费+专业服务费等"},
              {"科目": "应交税费——应交增值税（进项税额）", "金额": "可抵扣增值税"}
            ],
            "credit": [
              {"科目": "银行存款 / 应付账款 / 应付票据", "金额": "实际支付金额"}
            ],
            "大白话": "企业花钱买设备，设备增加记借方，进项税可以抵扣也记借方，钱少了记贷方。"
          },
          {
            "title": "外购需要安装的固定资产（购入时）",
            "debit": [
              {"科目": "在建工程", "金额": "买价+相关税费+运输费等"},
              {"科目": "应交税费——应交增值税（进项税额）", "金额": "可抵扣增值税"}
            ],
            "credit": [
              {"科目": "银行存款 / 应付账款", "金额": "实际支付金额"}
            ],
            "大白话": "设备还没装好不能用，先挂在'在建工程'里，等装好了再转固定资产。"
          },
          {
            "title": "外购需要安装的固定资产（安装完毕）",
            "debit": [
              {"科目": "固定资产", "金额": "在建工程总额"}
            ],
            "credit": [
              {"科目": "在建工程", "金额": "在建工程总额"}
            ],
            "大白话": "设备安装调试完毕，能正常使用了，从'在建工程'转到'固定资产'。"
          },
          {
            "title": "分期付款购入固定资产（购买日）",
            "debit": [
              {"科目": "固定资产 / 在建工程", "金额": "现值"},
              {"科目": "未确认融资费用", "金额": "合同价与现值的差额"}
            ],
            "credit": [
              {"科目": "长期应付款", "金额": "合同总价款"}
            ],
            "大白话": "分期付款买设备，固定资产按现值入账（不是合同总价），差额记'未确认融资费用'，相当于未来的利息。"
          },
          {
            "title": "分期付款支付每期款项",
            "debit": [
              {"科目": "长期应付款", "金额": "当期支付本金"}
            ],
            "credit": [
              {"科目": "银行存款", "金额": "实际支付金额"}
            ],
            "大白话": "每期还钱，冲减长期应付款，银行存款减少。"
          },
          {
            "title": "分期付款摊销融资费用",
            "debit": [
              {"科目": "在建工程 / 财务费用", "金额": "当期应摊销融资费用"}
            ],
            "credit": [
              {"科目": "未确认融资费用", "金额": "当期应摊销融资费用"}
            ],
            "大白话": "每期把未确认融资费用摊到在建工程（如果还没完工）或财务费用（如果已完工）里，相当于利息成本。"
          },
          {
            "title": "自行建造固定资产（购入工程物资）",
            "debit": [
              {"科目": "工程物资", "金额": "买价+运杂费等"},
              {"科目": "应交税费——应交增值税（进项税额）", "金额": "可抵扣增值税"}
            ],
            "credit": [
              {"科目": "银行存款 / 应付账款", "金额": "实际支付金额"}
            ],
            "大白话": "自己盖厂房，先买建筑材料，记'工程物资'，这是专门为在建工程准备的物资。"
          },
          {
            "title": "自行建造固定资产（领用工程物资）",
            "debit": [
              {"科目": "在建工程", "金额": "工程物资成本"}
            ],
            "credit": [
              {"科目": "工程物资", "金额": "工程物资成本"}
            ],
            "大白话": "材料运到工地开始施工，从'工程物资'转到'在建工程'。"
          },
          {
            "title": "自行建造固定资产（领用本企业原材料）",
            "debit": [
              {"科目": "在建工程", "金额": "原材料成本"}
            ],
            "credit": [
              {"科目": "原材料", "金额": "原材料成本"}
            ],
            "大白话": "把自家仓库的原材料拿去盖厂房，原材料减少，成本算到在建工程里。"
          },
          {
            "title": "自行建造固定资产（领用本企业库存商品）",
            "debit": [
              {"科目": "在建工程", "金额": "库存商品成本"}
            ],
            "credit": [
              {"科目": "库存商品", "金额": "库存商品成本"}
            ],
            "大白话": "把自家生产的产品用于在建工程，按成本转账，不确认收入。"
          },
          {
            "title": "自行建造固定资产（发生人工费用）",
            "debit": [
              {"科目": "在建工程", "金额": "应付职工薪酬"}
            ],
            "credit": [
              {"科目": "应付职工薪酬", "金额": "应付职工薪酬"}
            ],
            "大白话": "建筑工人的工资也算在建工程成本，借方记在建工程增加，贷方记欠工人的工资。"
          },
          {
            "title": "自行建造固定资产（发生其他费用）",
            "debit": [
              {"科目": "在建工程", "金额": "水电费+机械使用费等"}
            ],
            "credit": [
              {"科目": "银行存款", "金额": "实际支付金额"}
            ],
            "大白话": "施工过程中的水电费、机械租赁费等各种杂费，都堆到在建工程成本里。"
          },
          {
            "title": "自行建造固定资产（达到预定可使用状态）",
            "debit": [
              {"科目": "固定资产", "金额": "在建工程总额"}
            ],
            "credit": [
              {"科目": "在建工程", "金额": "在建工程总额"}
            ],
            "大白话": "厂房盖好了，能用了，把在建工程里的全部成本一次性转到固定资产。"
          },
          {
            "title": "自营建造固定资产（试运行销售）",
            "debit": [
              {"科目": "银行存款", "金额": "试运行销售收入"}
            ],
            "credit": [
              {"科目": "主营业务收入", "金额": "试运行销售收入"}
            ],
            "大白话": "设备还没正式投产，先试运行卖了点产品，这笔钱算收入，同时试运行发生的成本算当期费用。"
          },
          {
            "title": "存在弃置义务的固定资产（初始确认）",
            "debit": [
              {"科目": "固定资产", "金额": "弃置费用现值"}
            ],
            "credit": [
              {"科目": "预计负债", "金额": "弃置费用现值"}
            ],
            "大白话": "核电站这种特殊资产，未来拆除和治理污染的费用虽然几十年后才付，但现值要算进固定资产成本，同时挂一笔预计负债。"
          },
          {
            "title": "弃置义务预计负债利息（每期）",
            "debit": [
              {"科目": "财务费用", "金额": "预计负债期初余额×实际利率"}
            ],
            "credit": [
              {"科目": "预计负债", "金额": "同上"}
            ],
            "大白话": "预计负债像滚雪球一样越滚越大，每年增加的利息记财务费用，同时增加预计负债。"
          },
          {
            "title": "投资者投入固定资产",
            "debit": [
              {"科目": "固定资产", "金额": "合同约定价值（不公允的按公允价值）"}
            ],
            "credit": [
              {"科目": "实收资本 / 股本", "金额": "约定价值"}
            ],
            "大白话": "股东用设备入股，设备按约定价值入账，同时增加实收资本。"
          }
        ]
      },
      {
        "category": "二、折旧",
        "items": [
          {
            "title": "按月计提折旧",
            "debit": [
              {"科目": "制造费用 / 管理费用 / 销售费用 / 在建工程 / 研发支出 / 其他业务成本", "金额": "当月应计提折旧额"}
            ],
            "credit": [
              {"科目": "累计折旧", "金额": "当月应计提折旧额"}
            ],
            "大白话": "固定资产每月都在损耗，损耗价值记到用它的部门头上：生产车间记制造费用，管理部门记管理费用，销售部门记销售费用。"
          }
        ]
      },
      {
        "category": "三、后续支出",
        "items": [
          {
            "title": "资本化后续支出（转入在建工程）",
            "debit": [
              {"科目": "在建工程", "金额": "固定资产账面价值"},
              {"科目": "累计折旧", "金额": "已计提累计折旧"},
              {"科目": "固定资产减值准备", "金额": "已计提减值准备"}
            ],
            "credit": [
              {"科目": "固定资产", "金额": "原账面成本"}
            ],
            "大白话": "给老设备做大手术升级，先把原来的账面价值清零，转入在建工程。原价、折旧、减值准备一起冲掉。"
          },
          {
            "title": "资本化后续支出（发生改良支出）",
            "debit": [
              {"科目": "在建工程", "金额": "改良支出金额"}
            ],
            "credit": [
              {"科目": "银行存款 / 应付账款 / 应付职工薪酬等", "金额": "实际支出"}
            ],
            "大白话": "升级过程中花的材料费、人工费、设备费，都加到在建工程里。"
          },
          {
            "title": "资本化后续支出（完工转回固定资产）",
            "debit": [
              {"科目": "固定资产", "金额": "在建工程总额"}
            ],
            "credit": [
              {"科目": "在建工程", "金额": "在建工程总额"}
            ],
            "大白话": "升级完工，设备焕然一新，从在建工程转回固定资产，按新的成本和剩余寿命重新算折旧。"
          },
          {
            "title": "费用化后续支出",
            "debit": [
              {"科目": "管理费用 / 销售费用", "金额": "修理费金额"}
            ],
            "credit": [
              {"科目": "银行存款 / 原材料 / 应付职工薪酬等", "金额": "实际支出"}
            ],
            "大白话": "日常小修小补，不让设备变得更能赚钱，只是维持现状，费用直接记当期损益。"
          },
          {
            "title": "替换固定资产某组成部分",
            "debit": [
              {"科目": "营业外支出", "金额": "被替换部分账面价值"},
              {"科目": "银行存款", "金额": "新部件买价（如有）"}
            ],
            "credit": [
              {"科目": "在建工程", "金额": "被替换部分账面价值"}
            ],
            "大白话": "换发动机这种大部件，旧发动机的账面价值要一次性扔掉，记营业外支出，新发动机的成本重新算进在建工程。"
          }
        ]
      },
      {
        "category": "四、处置与清查",
        "items": [
          {
            "title": "固定资产转入清理",
            "debit": [
              {"科目": "固定资产清理", "金额": "账面价值"},
              {"科目": "累计折旧", "金额": "已计提累计折旧"},
              {"科目": "固定资产减值准备", "金额": "已计提减值准备"}
            ],
            "credit": [
              {"科目": "固定资产", "金额": "原账面成本"}
            ],
            "大白话": "准备卖掉或报废设备，先把固定资产的账面价值全部清零，转到'固定资产清理'这个临时科目里算账。"
          },
          {
            "title": "固定资产清理（发生清理费用）",
            "debit": [
              {"科目": "固定资产清理", "金额": "清理费用"}
            ],
            "credit": [
              {"科目": "银行存款", "金额": "清理费用"}
            ],
            "大白话": "拆设备、运废料花的钱，也算清理成本，记固定资产清理借方。"
          },
          {
            "title": "固定资产清理（取得处置价款/残料/保险赔偿）",
            "debit": [
              {"科目": "银行存款 / 原材料 / 其他应收款", "金额": "处置收入"}
            ],
            "credit": [
              {"科目": "固定资产清理", "金额": "处置收入"}
            ],
            "大白话": "卖设备收到的钱、废料变卖的收入、保险赔款，都记固定资产清理贷方，冲减清理成本。"
          },
          {
            "title": "固定资产清理完毕（出售/转让——产生利得）",
            "debit": [
              {"科目": "固定资产清理", "金额": "清理净收益"}
            ],
            "credit": [
              {"科目": "资产处置损益", "金额": "清理净收益"}
            ],
            "大白话": "卖设备赚了，固定资产清理贷方有余额，从借方转出，记资产处置损益贷方，增加当期利润。"
          },
          {
            "title": "固定资产清理完毕（出售/转让——产生损失）",
            "debit": [
              {"科目": "资产处置损益", "金额": "清理净损失"}
            ],
            "credit": [
              {"科目": "固定资产清理", "金额": "清理净损失"}
            ],
            "大白话": "卖设备亏了，固定资产清理借方有余额，从贷方转出，记资产处置损益借方，减少当期利润。"
          },
          {
            "title": "固定资产清理完毕（报废/毁损——产生利得）",
            "debit": [
              {"科目": "固定资产清理", "金额": "清理净收益"}
            ],
            "credit": [
              {"科目": "营业外收入", "金额": "清理净收益"}
            ],
            "大白话": "设备报废或天灾毁损，清理后有盈余，记营业外收入。"
          },
          {
            "title": "固定资产清理完毕（报废/毁损——产生损失）",
            "debit": [
              {"科目": "营业外支出", "金额": "清理净损失"}
            ],
            "credit": [
              {"科目": "固定资产清理", "金额": "清理净损失"}
            ],
            "大白话": "设备报废或天灾毁损，清理后亏了，记营业外支出。"
          },
          {
            "title": "固定资产盘盈",
            "debit": [
              {"科目": "固定资产", "金额": "重置成本"}
            ],
            "credit": [
              {"科目": "以前年度损益调整", "金额": "重置成本"}
            ],
            "大白话": "固定资产盘盈不记当期收入，而是记'以前年度损益调整'，因为盘盈通常说明以前年度漏记账了。"
          },
          {
            "title": "固定资产盘亏（发现时）",
            "debit": [
              {"科目": "待处理财产损溢", "金额": "账面价值"},
              {"科目": "累计折旧", "金额": "已计提折旧"},
              {"科目": "固定资产减值准备", "金额": "已计提减值"}
            ],
            "credit": [
              {"科目": "固定资产", "金额": "原账面成本"}
            ],
            "大白话": "设备丢了或坏了，先挂'待处理财产损溢'，把原价、折旧、减值一起冲掉。"
          },
          {
            "title": "固定资产盘亏（处理时——责任人赔偿）",
            "debit": [
              {"科目": "其他应收款", "金额": "赔偿款"}
            ],
            "credit": [
              {"科目": "待处理财产损溢", "金额": "赔偿款"}
            ],
            "大白话": "有人赔的部分记其他应收款，冲减待处理财产损溢。"
          },
          {
            "title": "固定资产盘亏（处理时——净损失）",
            "debit": [
              {"科目": "营业外支出", "金额": "净损失"}
            ],
            "credit": [
              {"科目": "待处理财产损溢", "金额": "净损失"}
            ],
            "大白话": "没人赔的部分，净损失记营业外支出。"
          }
        ]
      }
    ]
  }
}
