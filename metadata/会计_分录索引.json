{
  "会计-第2章": {
    "title": "第二章 存货 — 本章会计分录",
    "entries": [
      {
        "category": "一、外购存货",
        "items": [
          {
            "title": "外购存货（款已付，材料已入库）",
            "debit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "实际成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款",
                "金额": "价税合计"
              }
            ],
            "大白话": "企业花钱买材料，材料增加了记借方，同时拿到进项税可以抵扣，银行存款减少记贷方。"
          },
          {
            "title": "外购存货（款未付，材料已入库）",
            "debit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "实际成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "应付账款 / 应付票据",
                "金额": "价税合计"
              }
            ],
            "大白话": "材料和税照样增加，但钱还没付，所以欠供应商的债务增加，记应付账款贷方。"
          },
          {
            "title": "外购存货（款已付，材料在途）",
            "debit": [
              {
                "科目": "在途物资",
                "金额": "实际成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款",
                "金额": "价税合计"
              }
            ],
            "大白话": "钱付了但货还在路上，不能记原材料，先挂在'在途物资'里，等货到再转原材料。"
          },
          {
            "title": "预付货款",
            "debit": [
              {
                "科目": "预付账款",
                "金额": "预付金额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款",
                "金额": "预付金额"
              }
            ],
            "大白话": "先打定金给供应商，钱出了但货还没到，记一笔预付账款，代表未来能收到货的债权。"
          },
          {
            "title": "收到预购材料，补付货款",
            "debit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "实际成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "预付账款",
                "金额": "已预付金额"
              },
              {
                "科目": "银行存款",
                "金额": "补付差额"
              }
            ],
            "大白话": "货到了，把之前预付的定金冲掉，不够的部分再补现金。"
          }
        ]
      },
      {
        "category": "二、委托加工物资",
        "items": [
          {
            "title": "发出材料委托加工",
            "debit": [
              {
                "科目": "委托加工物资",
                "金额": "材料实际成本"
              }
            ],
            "credit": [
              {
                "科目": "原材料",
                "金额": "材料实际成本"
              }
            ],
            "大白话": "原材料从自家仓库搬到加工厂，所有权没变，只是换个科目记账，从'原材料'转到'委托加工物资'。"
          },
          {
            "title": "支付加工费、运费",
            "debit": [
              {
                "科目": "委托加工物资",
                "金额": "加工费+运费"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "价税合计"
              }
            ],
            "大白话": "加工费和运费都算到委托加工物资成本里，进项税单独记。"
          },
          {
            "title": "支付消费税（收回后直接销售）",
            "debit": [
              {
                "科目": "委托加工物资",
                "金额": "消费税税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "消费税税额"
              }
            ],
            "大白话": "如果收回的货直接卖，消费税不能抵扣，直接加到货物成本里。"
          },
          {
            "title": "支付消费税（收回后继续生产应税消费品）",
            "debit": [
              {
                "科目": "应交税费——应交消费税",
                "金额": "消费税税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "消费税税额"
              }
            ],
            "大白话": "如果收回后继续加工成新的应税消费品，消费税可以抵扣，先记在'应交税费'借方，以后卖成品时抵扣。"
          },
          {
            "title": "加工完成收回",
            "debit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "实际成本合计"
              }
            ],
            "credit": [
              {
                "科目": "委托加工物资",
                "金额": "实际成本合计"
              }
            ],
            "大白话": "加工完了，货回到自家仓库，从'委托加工物资'转回'原材料'或'库存商品'。"
          }
        ]
      },
      {
        "category": "三、存货跌价准备",
        "items": [
          {
            "title": "计提存货跌价准备",
            "debit": [
              {
                "科目": "资产减值损失",
                "金额": "成本-可变现净值"
              }
            ],
            "credit": [
              {
                "科目": "存货跌价准备",
                "金额": "成本-可变现净值"
              }
            ],
            "大白话": "货贬值了，在利润表上确认一笔损失，同时在资产负债表上给存货打个折扣，'存货跌价准备'就是折扣科目。"
          },
          {
            "title": "转回存货跌价准备",
            "debit": [
              {
                "科目": "存货跌价准备",
                "金额": "可转回金额"
              }
            ],
            "credit": [
              {
                "科目": "资产减值损失",
                "金额": "可转回金额"
              }
            ],
            "大白话": "市场回暖，货值回升了，把之前计提的跌价准备冲回一部分，但不能超过原来计提的金额。"
          },
          {
            "title": "结转已计提跌价准备的存货销售成本",
            "debit": [
              {
                "科目": "主营业务成本",
                "金额": "账面价值"
              },
              {
                "科目": "存货跌价准备",
                "金额": "已计提金额"
              }
            ],
            "credit": [
              {
                "科目": "库存商品",
                "金额": "原账面成本"
              }
            ],
            "大白话": "卖货时，把存货和对应的跌价准备一起结转，主营业务成本只按账面价值算（成本减去跌价准备）。"
          }
        ]
      },
      {
        "category": "四、存货清查（盘盈盘亏）",
        "items": [
          {
            "title": "发现存货盘亏",
            "debit": [
              {
                "科目": "待处理财产损溢",
                "金额": "盘亏成本×(1+税率)"
              }
            ],
            "credit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "盘亏成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额转出）",
                "金额": "盘亏成本×税率"
              }
            ],
            "大白话": "货少了，先把差额挂到'待处理财产损溢'。如果是因为管理不善造成的，之前抵扣的进项税要吐出来，记'进项税额转出'。"
          },
          {
            "title": "盘亏处理（管理不善）",
            "debit": [
              {
                "科目": "管理费用",
                "金额": "净损失"
              },
              {
                "科目": "其他应收款——责任人",
                "金额": "赔偿款"
              },
              {
                "科目": "原材料",
                "金额": "残料价值"
              }
            ],
            "credit": [
              {
                "科目": "待处理财产损溢",
                "金额": "合计"
              }
            ],
            "大白话": "正常管理不善造成的盘亏，损失记管理费用；有人赔的记其他应收款；残料能用的记原材料。"
          },
          {
            "title": "盘亏处理（非常损失）",
            "debit": [
              {
                "科目": "营业外支出——非常损失",
                "金额": "净损失"
              },
              {
                "科目": "其他应收款——保险公司",
                "金额": "保险赔偿"
              }
            ],
            "credit": [
              {
                "科目": "待处理财产损溢",
                "金额": "合计"
              }
            ],
            "大白话": "自然灾害等非常原因造成的盘亏，损失记营业外支出，保险赔偿记其他应收款。"
          },
          {
            "title": "发现存货盘盈",
            "debit": [
              {
                "科目": "原材料 / 库存商品",
                "金额": "重置成本"
              }
            ],
            "credit": [
              {
                "科目": "待处理财产损溢",
                "金额": "重置成本"
              }
            ],
            "大白话": "货多了，先按重置成本记增加，同时挂'待处理财产损溢'等批准。"
          },
          {
            "title": "盘盈处理",
            "debit": [
              {
                "科目": "待处理财产损溢",
                "金额": "重置成本"
              }
            ],
            "credit": [
              {
                "科目": "管理费用",
                "金额": "重置成本"
              }
            ],
            "大白话": "盘盈一般冲减管理费用，相当于管理效率提高省下来的钱。"
          }
        ]
      },
      {
        "category": "五、计划成本法（补充）",
        "items": [
          {
            "title": "购入材料（计划成本法）",
            "debit": [
              {
                "科目": "材料采购",
                "金额": "实际成本"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "增值税发票注明税额"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "价税合计"
              }
            ],
            "大白话": "计划成本法下，买东西先按实际成本记'材料采购'，这是个过渡科目。"
          },
          {
            "title": "材料入库（计划成本法）",
            "debit": [
              {
                "科目": "原材料",
                "金额": "计划成本"
              }
            ],
            "credit": [
              {
                "科目": "材料采购",
                "金额": "实际成本"
              },
              {
                "科目": "材料成本差异",
                "金额": "差额（或借方）"
              }
            ],
            "大白话": "货入库了，原材料按计划成本记。实际成本和计划成本的差额记'材料成本差异'，超支记借方，节约记贷方。"
          },
          {
            "title": "发出材料（计划成本法）",
            "debit": [
              {
                "科目": "生产成本 / 制造费用 / 管理费用",
                "金额": "计划成本"
              }
            ],
            "credit": [
              {
                "科目": "原材料",
                "金额": "计划成本"
              }
            ],
            "大白话": "领用时先按计划成本转走，月末再调整差异。"
          },
          {
            "title": "结转材料成本差异（超支）",
            "debit": [
              {
                "科目": "生产成本 / 制造费用 / 管理费用",
                "金额": "差异金额"
              }
            ],
            "credit": [
              {
                "科目": "材料成本差异",
                "金额": "差异金额"
              }
            ],
            "大白话": "月末把'材料成本差异'分摊到领用材料的车间和部门。超支差异是实际比计划贵，所以要增加成本。"
          },
          {
            "title": "结转材料成本差异（节约）",
            "debit": [
              {
                "科目": "材料成本差异",
                "金额": "差异金额"
              }
            ],
            "credit": [
              {
                "科目": "生产成本 / 制造费用 / 管理费用",
                "金额": "差异金额"
              }
            ],
            "大白话": "节约差异是实际比计划便宜，冲减成本，分录和超支相反。"
          }
        ]
      }
    ]
  },
  "会计-第3章": {
    "title": "第三章 固定资产 — 本章会计分录",
    "entries": [
      {
        "category": "一、初始计量",
        "items": [
          {
            "title": "外购不需安装的固定资产",
            "debit": [
              {
                "科目": "固定资产",
                "金额": "买价+相关税费+运输费+装卸费+安装费+专业服务费等"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "可抵扣增值税"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款 / 应付票据",
                "金额": "实际支付金额"
              }
            ],
            "大白话": "企业花钱买设备，设备增加记借方，进项税可以抵扣也记借方，钱少了记贷方。"
          },
          {
            "title": "外购需要安装的固定资产（购入时）",
            "debit": [
              {
                "科目": "在建工程",
                "金额": "买价+相关税费+运输费等"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "可抵扣增值税"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "实际支付金额"
              }
            ],
            "大白话": "设备还没装好不能用，先挂在'在建工程'里，等装好了再转固定资产。"
          },
          {
            "title": "外购需要安装的固定资产（安装完毕）",
            "debit": [
              {
                "科目": "固定资产",
                "金额": "在建工程总额"
              }
            ],
            "credit": [
              {
                "科目": "在建工程",
                "金额": "在建工程总额"
              }
            ],
            "大白话": "设备安装调试完毕，能正常使用了，从'在建工程'转到'固定资产'。"
          },
          {
            "title": "分期付款购入固定资产（购买日）",
            "debit": [
              {
                "科目": "固定资产 / 在建工程",
                "金额": "现值"
              },
              {
                "科目": "未确认融资费用",
                "金额": "合同价与现值的差额"
              }
            ],
            "credit": [
              {
                "科目": "长期应付款",
                "金额": "合同总价款"
              }
            ],
            "大白话": "分期付款买设备，固定资产按现值入账（不是合同总价），差额记'未确认融资费用'，相当于未来的利息。"
          },
          {
            "title": "分期付款支付每期款项",
            "debit": [
              {
                "科目": "长期应付款",
                "金额": "当期支付本金"
              }
            ],
            "credit": [
              {
                "科目": "银行存款",
                "金额": "实际支付金额"
              }
            ],
            "大白话": "每期还钱，冲减长期应付款，银行存款减少。"
          },
          {
            "title": "分期付款摊销融资费用",
            "debit": [
              {
                "科目": "在建工程 / 财务费用",
                "金额": "当期应摊销融资费用"
              }
            ],
            "credit": [
              {
                "科目": "未确认融资费用",
                "金额": "当期应摊销融资费用"
              }
            ],
            "大白话": "每期把未确认融资费用摊到在建工程（如果还没完工）或财务费用（如果已完工）里，相当于利息成本。"
          },
          {
            "title": "自行建造固定资产（购入工程物资）",
            "debit": [
              {
                "科目": "工程物资",
                "金额": "买价+运杂费等"
              },
              {
                "科目": "应交税费——应交增值税（进项税额）",
                "金额": "可抵扣增值税"
              }
            ],
            "credit": [
              {
                "科目": "银行存款 / 应付账款",
                "金额": "实际支付金额"
              }
            ],
            "大白话": "自己盖厂房，先买建筑材料，记'工程物资'，这是专门为在建工程准备的物资。"
          },
          {
            "title": "自行建造固定资产（领用工程物资）",
            "debit": [
              {
                "科目": "在建工程",
                "金额": "工程物资成本"
              }
            ],
            "credit": [
              {
                "科目": "工程物资",
                "金额": "工程物资成本"
              }
            ],
            "大白话": "材料运到工地开始施工，从'工程物资'转到'在建工程'。"
          },
          {
            "title": "自行建造固定资产（领用本企业原材料）",
            "debit": [
              {
                "科目": "在建工程",
                "金额": "原材料成本"
              }
            ],
            "credit": [
              {
                "科目": "原材料",
                "金额": "原材料成本"
              }
            ],
            "大白话": "把自家仓库的原材料拿去盖厂房，原材料减少，成本算到在建工程里。"
          },
          {
            "title": "自行建造固定资产（领用本企业库存商品）",
